#!/usr/bin/env bash
# gitstat - JSON summary of git repository state

set -e

usage() {
  cat <<'EOF'
Usage: gitstat [options]

Output a JSON summary of the current git repository state.

Options:
  -p, --pretty   Pretty-print the JSON output
  -h, --help     Show this help

Output fields:
  branch, sha, message, author, dirty, staged, unstaged, untracked,
  conflicts, ahead, behind, stashes, remoteUrl, detached

Examples:
  gitstat
  gitstat --pretty
  gitstat | python3 -m json.tool
EOF
  exit 0
}

PRETTY=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--pretty) PRETTY=true; shift ;;
    -h|--help)   usage ;;
    -*)          echo "Unknown option: $1" >&2; exit 1 ;;
    *)           shift ;;
  esac
done

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo '{"error":"not a git repository"}' >&2
  exit 1
fi

# Gather data
branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
detached=false
if [[ -z "$branch" ]]; then
  branch=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  detached=true
fi

sha=$(git rev-parse HEAD 2>/dev/null || echo "")
message=$(git log -1 --format=%s 2>/dev/null || echo "")
author=$(git log -1 --format=%an 2>/dev/null || echo "")

staged=$(git diff --cached --numstat 2>/dev/null | wc -l | tr -d ' ')
unstaged=$(git diff --numstat 2>/dev/null | wc -l | tr -d ' ')
untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null | wc -l | tr -d ' ')

dirty=false
[[ "$staged" -gt 0 || "$unstaged" -gt 0 || "$untracked" -gt 0 || "$conflicts" -gt 0 ]] && dirty=true

ahead=0
behind=0
if upstream=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null); then
  ahead=$(git rev-list --count "$upstream..HEAD" 2>/dev/null || echo 0)
  behind=$(git rev-list --count "HEAD..$upstream" 2>/dev/null || echo 0)
fi

stashes=$(git stash list 2>/dev/null | wc -l | tr -d ' ')

remote_url=$(git remote get-url origin 2>/dev/null || echo "")

# JSON escape helper
jesc() { printf '%s' "$1" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()), end="")' 2>/dev/null || printf '"%s"' "$(printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g')"; }

json=$(printf '{"branch":%s,"sha":%s,"message":%s,"author":%s,"dirty":%s,"staged":%d,"unstaged":%d,"untracked":%d,"conflicts":%d,"ahead":%d,"behind":%d,"stashes":%d,"remoteUrl":%s,"detached":%s}' \
  "$(jesc "$branch")" \
  "$(jesc "$sha")" \
  "$(jesc "$message")" \
  "$(jesc "$author")" \
  "$dirty" \
  "$staged" "$unstaged" "$untracked" "$conflicts" \
  "$ahead" "$behind" "$stashes" \
  "$(jesc "$remote_url")" \
  "$detached")

if [[ "$PRETTY" == true ]]; then
  echo "$json" | python3 -m json.tool 2>/dev/null || echo "$json"
else
  echo "$json"
fi
