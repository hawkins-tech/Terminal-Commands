#!/usr/bin/env python3

import argparse
import re
import signal
import subprocess
import sys
from typing import Pattern


def compile_pattern(pattern: str, fixed: bool, ignore_case: bool) -> Pattern[str]:
    flags = re.IGNORECASE if ignore_case else 0
    if fixed:
        pattern = re.escape(pattern)
    return re.compile(pattern, flags)


def terminate_process_group() -> None:
    try:
        pgid = os.getpgrp()
        os.killpg(pgid, signal.SIGTERM)
    except Exception:
        pass


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="firstmatch",
        description="Read stdin, print the first matching line, then exit immediately."
    )
    parser.add_argument("pattern", help="Regex pattern to match")
    parser.add_argument(
        "-i",
        "--ignore-case",
        action="store_true",
        help="Case-insensitive matching",
    )
    parser.add_argument(
        "-F",
        "--fixed-string",
        action="store_true",
        help="Treat pattern as a literal string instead of regex",
    )
    parser.add_argument(
        "-v",
        "--invert-match",
        action="store_true",
        help="Match the first line that does NOT match the pattern",
    )
    parser.add_argument(
        "-n",
        "--line-number",
        action="store_true",
        help="Prefix output with the 1-based line number",
    )
    parser.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="Do not print the line, just exit with success on first match",
    )
    args = parser.parse_args()

    matcher = compile_pattern(args.pattern, args.fixed_string, args.ignore_case)

    line_number = 0

    try:
        for raw_line in sys.stdin:
            line_number += 1
            line = raw_line.rstrip("\n")
            matched = matcher.search(line) is not None

            if args.invert_match:
                matched = not matched

            if matched:
                if not args.quiet:
                    if args.line_number:
                        sys.stdout.write(f"{line_number}:{raw_line}")
                    else:
                        sys.stdout.write(raw_line)
                    sys.stdout.flush()
                return 0

        return 1

    except BrokenPipeError:
        return 1
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    import os
    raise SystemExit(main())
